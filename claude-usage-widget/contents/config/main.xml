    <entry name="projectShortcutLabel" type="String">
      <default></default>
    </entry>
    <entry name="projectShortcutUrl" type="String">
      <default></default>
    </entry>
    <entry name="minimalView" type="Bool">
      <default>false</default>
    </entry>
  </group>
</kcfg>
