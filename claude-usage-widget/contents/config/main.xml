    <entry name="backgroundOpacity" type="Double">
      <default>0.0</default>
    </entry>
    <entry name="terminalApp" type="String">
      <default>konsole</default>
    </entry>
    <entry name="timerEnabled" type="Bool">
      <default>true</default>
